rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function ADMIN_UID_ALLOWLIST() {
      return [
        "Xeo42uq9vEg36udWuXzR0Xv56qt1"
      ];
    }

    function isAdmin() {
      return request.auth != null && request.auth.uid in ADMIN_UID_ALLOWLIST();
    }

    // Public read access to portfolio data
    match /projects/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /skills/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /experience/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /education/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /settings/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
