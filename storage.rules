rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function ADMIN_UID_ALLOWLIST() {
      return [
        "Xeo42uq9vEg36udWuXzR0Xv56qt1"
      ];
    }

    function isAdmin() {
      return request.auth != null && request.auth.uid in ADMIN_UID_ALLOWLIST();
    }

    match /{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
